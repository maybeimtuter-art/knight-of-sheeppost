
///@param text id
function scr_game_text(_text_id){
	
	switch(_text_id){
		case "npc 1":
		scr_text("tribal hello pal ima 1")
		
		
			break;
			
		case "npc 2":
		scr_text("tribal hello pal ima 2")
		scr_text("pale test ")
		scr_text("good job if you see that")
		
			break;
			
			
		case "npc 3":
		scr_text("tribal hello pal ima 3")
		
			break;
	
	
	
	
}

}